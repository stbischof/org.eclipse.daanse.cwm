      <eLiterals name="LOW" value="1">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Der Vorfall tritt wahrscheinlich frühestens in 6 Jahren ein bzw. ist noch nie oder vor mehr als 6 Jahren eingetreten."/>
          <details key="documentation.en" value="The incident will probably not occur within the next 6 years, occurred more than 6 years ago or has not occurred yet."/>
          <details key="caption.de" value="GERING"/>
          <details key="caption.en" value="LOW"/>
        </eAnnotations>
      </eLiterals>
      <eLiterals name="MEDIUM" value="2">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Der Vorfall tritt wahrscheinlich in den nächsten 4-6 Jahren ein bzw. ist in den letzten 4-6 Jahren eingetreten."/>
          <details key="documentation.en" value="The incident will probably occur within the next 4 to 6 years or has occurred during the past 4 to 6 years."/>
          <details key="caption.de" value="MITTEL"/>
          <details key="caption.en" value="MEDIUM"/>
        </eAnnotations>
      </eLiterals>
      <eLiterals name="HIGH" value="3">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Der Vorfall tritt wahrscheinlich in den nächsten 1-3 Jahren ein bzw. ist in den letzten 1-3 Jahren eingetreten."/>
          <details key="documentation.en" value="The incident will probably occur within the next 1 to 3 years or has occurred during the past 1 to 3 years."/>
          <details key="caption.de" value="HOCH"/>
          <details key="caption.en" value="HIGH"/>
        </eAnnotations>
      </eLiterals>
      <eLiterals name="VERY_HIGH" value="4">
        <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
          <details key="documentation" value="Der Vorfall tritt wahrscheinlich im nächsten Jahr ein bzw. ist im letzten Jahr eingetreten."/>
          <details key="documentation.en" value="The incident will probably occur within the next year or has occurred during the past year."/>
          <details key="caption.de" value="SEHR_HOCH"/>
          <details key="caption.en" value="VERY_HIGH"/>
        </eAnnotations>
      </eLiterals>
    </eClassifiers>
