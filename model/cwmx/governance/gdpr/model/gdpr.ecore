        <details key="documentation.en" value="Privacy rating of a data field: links a generic data field (base/dataclass/DataField) to its GDPR personal-data category according to Art. 4 / Art. 9 GDPR."/>
        <details key="caption.de" value="Datenfeld-Datenschutzbewertung"/>
