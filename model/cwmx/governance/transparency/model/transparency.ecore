    </eLiterals>
    <eLiterals name="ON_REQUEST" value="3" literal="ON_REQUEST">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Zugang nur auf Antrag gemaess §9-§15 ThuerTG"/>
        <details key="documentation.en" value="Access only on request according to §9-§15 ThuerTG"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="EXCLUDED" value="4" literal="EXCLUDED">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Von der Veroeffentlichung ausgeschlossen gemaess §12/§13 ThuerTG"/>
        <details key="documentation.en" value="Excluded from publication according to §12/§13 ThuerTG"/>
