    nsPrefix="transparency">
  <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
    <details key="basePackage" value="org.eclipse.daanse.cwm.model.cwmx.governance"/>
    <details key="documentation" value="Paket mit Modellen zur Bewertung von Transparenzpflichten gemaess Thueringer Transparenzgesetz (ThuerTG)"/>
    <details key="documentation.en" value="Package of models for transparency obligation assessment according to Thuringian Transparency Act (ThuerTG)"/>
    <details key="caption.de" value="Transparenzpflichten ThuerTG"/>
    <details key="caption.en" value="Transparency Obligations ThuerTG"/>
  </eAnnotations>
  <eClassifiers xsi:type="ecore:EEnum" name="PublicationMode">
    <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
      <details key="documentation" value="Veroeffentlichungsart gemaess ThuerTG: proaktiv (§5/§6), auf Antrag (§9-§15) oder ausgeschlossen (§12/§13)"/>
      <details key="documentation.en" value="Publication mode according to ThuerTG: proactive (§5/§6), on request (§9-§15) or excluded (§12/§13)"/>
      <details key="caption.de" value="Veroeffentlichungsart"/>
      <details key="caption.en" value="Publication Mode"/>
    </eAnnotations>
    <eLiterals name="UNEDITED" literal="UNEDITED">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Nicht bearbeitet"/>
        <details key="documentation.en" value="Unedited"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="PROACTIVE_MANDATORY" value="1" literal="PROACTIVE_MANDATORY">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Proaktive Veroeffentlichungspflicht gemaess §5/§6 ThuerTG"/>
        <details key="documentation.en" value="Mandatory proactive publication according to §5/§6 ThuerTG"/>
      </eAnnotations>
    </eLiterals>
    <eLiterals name="PROACTIVE_OPTIONAL" value="2" literal="PROACTIVE_OPTIONAL">
      <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
        <details key="documentation" value="Freiwillige proaktive Veroeffentlichung"/>
        <details key="documentation.en" value="Voluntary proactive publication"/>
