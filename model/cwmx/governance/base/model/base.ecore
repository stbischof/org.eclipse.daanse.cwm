  <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
    <details key="basePackage" value="org.eclipse.daanse.cwm.model.cwmx.governance"/>
    <details key="documentation" value="Gemeinsame Basistypen fuer Governance-Modelle (Datenschutz, Transparenz, KRITIS): generische Datenklassen/-felder sowie technisch-organisatorische Massnahmen (TOM)."/>
    <details key="documentation.en" value="Shared base types for governance models (data protection, transparency, KRITIS): generic data classes / fields and technical &amp; organizational measures (TOM)."/>
    <details key="caption.de" value="Governance-Basis"/>
    <details key="caption.en" value="Governance Base"/>
  </eAnnotations>
