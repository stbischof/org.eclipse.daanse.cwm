      <details key="documentation.en" value="Generic data classes and data fields for data classification (verbal, Ecore- or CWM-based). Domain-specific extensions (e.g. privacy level, personal-data category) live in their respective domain models."/>
      <details key="caption.de" value="Datenklassifikation"/>
      <details key="caption.en" value="Data Classification"/>
    </eAnnotations>
