<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="critis" nsURI="https://www.daanse.org/spec/org.eclipse.daanse.cwm.model.cwmx.governance.critis"
    nsPrefix="critis">
  <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
    <details key="basePackage" value="org.eclipse.daanse.cwm.model.cwmx.governance"/>
    <details key="documentation" value="Platzhalter-Paket fuer Modelle zu Kritischen Infrastrukturen (KRITIS) gemaess BSI-KritisV. Wird nutzbar, sobald die KRITIS-spezifischen Klassen ergaenzt sind. Wiederverwendet TOM aus base/tom."/>
    <details key="documentation.en" value="Placeholder package for Critical Infrastructure (KRITIS) models according to BSI-KritisV. Becomes usable once KRITIS-specific classes are added. Reuses TOM from base/tom."/>
    <details key="caption.de" value="KRITIS"/>
    <details key="caption.en" value="Critical Infrastructure"/>
  </eAnnotations>
</ecore:EPackage>
